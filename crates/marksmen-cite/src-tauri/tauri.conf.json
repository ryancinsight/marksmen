{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "marksmen-cite",
  "version": "0.1.0",
  "identifier": "com.ryancinsight.marksmen-cite",
  "build": {
    "frontendDist": "../src"
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "dmg", "deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Ryan Clanton",
    "shortDescription": "Marksmen Cite",
    "longDescription": "Marksmen Cite is a companion citation and bibliography manager."
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Marksmen Cite",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "decorations": true,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
