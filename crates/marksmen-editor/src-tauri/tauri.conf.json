{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "marksmen-editor",
  "version": "0.1.0",
  "identifier": "com.ryancinsight.marksmen-editor",
  "build": {
    "frontendDist": "../src"
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "dmg", "deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Ryan Clanton",
    "shortDescription": "Marksmen Editor",
    "longDescription": "Marksmen Editor is a professional markdown editor."
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Marksmen Editor",
        "width": 1440,
        "height": 900,
        "minWidth": 900,
        "minHeight": 640,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
